{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GetMemoryRequest",
  "description": "Request for [`METHOD_MEMORY_GET`].",
  "type": "object",
  "properties": {
    "key": {
      "description": "Exact key to look up.",
      "type": "string"
    },
    "scope": {
      "description": "Scope to read from.",
      "$ref": "#/$defs/MemoryScope"
    }
  },
  "required": [
    "scope",
    "key"
  ],
  "$defs": {
    "MemoryScope": {
      "description": "Memory scope identifier. The scope id is derived by the plugin from\nthese fields as a flat namespace. Project-wide memory: `project_id`\nonly. Per-agent: `project_id` + `agent_id`. Per-task: `project_id` +\n`agent_id` + `task_id`.",
      "type": "object",
      "properties": {
        "agent_id": {
          "description": "Optional agent identifier (per-agent or per-task scopes).",
          "type": [
            "string",
            "null"
          ]
        },
        "project_id": {
          "description": "Project identifier (required).",
          "type": "string"
        },
        "task_id": {
          "description": "Optional task identifier (per-task scopes only).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "project_id"
      ]
    }
  }
}
